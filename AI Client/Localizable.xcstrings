          }
        }
      }
    },
    "apiFormat.vertexAIExpress.requestFooter": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertex Express uses a {model} placeholder in the default endpoint and replaces it with the current model ID before sending."
          }
        },
        "zh-Hans": {
          "stringUnit": {
