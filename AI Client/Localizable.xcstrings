    "Anthropic Messages sends the API Key as x-api-key and automatically adds anthropic-version. The API Key is stored in Keychain.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Anthropic Messages sends the API Key as x-api-key and automatically adds anthropic-version. The API Key is stored in Keychain."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "new",
            "value": "Anthropic Messages 会通过 x-api-key 发送 API Key，并自动添加 anthropic-version。API Key 会存入钥匙串。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "new",
            "value": "Anthropic Messages 會透過 x-api-key 傳送 API Key，並自動加入 anthropic-version。API Key 會存入鑰匙圈。"
          }
        }
      }
    },
