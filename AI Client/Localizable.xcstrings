    "agent.skills.promptAppendixIntro": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The following AI Client Agent Skills are continuously enabled in the current conversation. They are text instruction packages and do not mean this device can execute scripts, Python, shell commands, subprocesses, or undeclared tools. Follow them only when they are relevant to the user's request."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下面是用户在当前对话中持续启用的 AI Client Agent Skills。它们是文本指令包，不代表本机可以执行脚本、Python、shell、子进程或未声明工具。仅在与用户请求相关时遵循。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "以下是使用者在目前對話中持續啟用的 AI Client Agent Skills。它們是文字指令包，不代表本機可以執行指令碼、Python、shell、子行程或未宣告的工具。僅在與使用者請求相關時遵循。"
          }
        }
      }
    },
