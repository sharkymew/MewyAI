          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Responses API 默认 endpoint 是 responses，模型参数会按 Responses 字段名发送。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Responses API 預設 endpoint 為 responses，模型參數會依 Responses 欄位名稱傳送。"
          }
        }
      }
    },
    "apiFormat.vertexAIExpress.requestFooter" : {
