          }
        }
      }
    },
    "App 在后台或非活跃状态完成普通对话后，会发送一条本机通知。临时聊天、失败或手动停止不会通知。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "When a regular chat finishes while the app is in the background or inactive, a local notification is sent. Temporary chats, failures, and manually stopped chats do not send notifications."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "new",
            "value": "App 在后台或非活跃状态完成普通对话后，会发送一条本机通知。临时聊天、失败或手动停止不会通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "new",
            "value": "App 在背景或非活躍狀態完成一般對話後，會傳送一則本機通知。臨時聊天、失敗或手動停止不會通知。"
          }
        }
      }
    },
