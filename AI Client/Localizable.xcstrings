    "The current model does not support image input, and an image message in the context does not have a usable hidden description yet. Try again later, or switch to an image-capable multimodal model.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "The current model does not support image input, and an image message in the context does not have a usable hidden description yet. Try again later, or switch to an image-capable multimodal model."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "new",
            "value": "当前模型不支持图片输入，且上下文中的一条图片消息还没有可用的隐藏描述。请稍后重试，或切换到支持图片的多模态模型。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "new",
            "value": "目前模型不支援圖片輸入，且上下文中的一則圖片訊息尚未有可用的隱藏描述。請稍後重試，或切換到支援圖片的多模態模型。"
          }
        }
      }
    },
    "The current model does not support image input, and this image message does not have a usable hidden description yet. Switch to an image-capable multimodal model and try again.": {
