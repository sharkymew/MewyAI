    "apiFormat.anthropicMessages.requestFooter": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Anthropic Messages uses v1/messages as the default endpoint, sends the API Key as x-api-key, and automatically adds anthropic-version. Max Tokens only applies to the current configuration."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Anthropic Messages 默认 endpoint 是 v1/messages，会把 API Key 作为 x-api-key 发送，并自动附加 anthropic-version。Max Tokens 仅对当前配置生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Anthropic Messages 預設 endpoint 為 v1/messages，會將 API Key 作為 x-api-key 傳送，並自動附加 anthropic-version。Max Tokens 僅對目前設定生效。"
          }
        }
      }
    },
    "apiFormat.openAIChatCompletions.requestFooter": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat Completions combines Endpoint with Base URL to form the final request URL. The default endpoint is chat/completions."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat Completions 会把 Endpoint 与 Base URL 拼成最终请求地址，默认 endpoint 是 chat/completions。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
