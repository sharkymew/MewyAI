    "Vertex Express adds the API Key to the request query. Error diagnostics hide the query, and the API Key is stored in Keychain.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Vertex Express adds the API Key to the request query. Error diagnostics hide the query, and the API Key is stored in Keychain."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "new",
            "value": "Vertex Express 会将 API Key 添加到请求查询参数。错误诊断会隐藏查询参数，API Key 会存入钥匙串。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "new",
            "value": "Vertex Express 會將 API Key 加入請求查詢參數。錯誤診斷會隱藏查詢參數，API Key 會存入鑰匙圈。"
          }
        }
      }
    },
